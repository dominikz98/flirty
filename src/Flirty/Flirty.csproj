<Project Sdk="Microsoft.NET.Sdk">

  <!-- Gemeinsame Properties (TFM, Nullable, ImplicitUsings, WarnAsError) kommen aus Directory.Build.props. -->
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Flirty</PackageId>
    <Description>Chatbot-/Dialog-Engine für .NET: Persistenz, Branching, Loops, Resume und Trigger. ASP.NET-frei nutzbar.</Description>
    <Authors>Flirty</Authors>
    <PackageTags>chatbot;dialog;conversation;engine;branching;mediator</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

</Project>
