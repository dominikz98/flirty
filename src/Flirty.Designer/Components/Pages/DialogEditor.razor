@* Bewusst NICHT "DialogDetail" genannt: der Komponententyp würde sonst den gleichnamigen
   Sichttyp Flirty.Runtime.Admin.DialogDetail verdecken. *@
@page "/dialogs/{Id:guid}"
@rendermode InteractiveServer
@using Mediator
@using Flirty.Domain
@using Flirty.Runtime.Admin
@inject FlirtyAdminGateway Admin
@inject NavigationManager Navigation

<PageTitle>@(_detail?.Dialog.Name ?? "Dialog") · Flirty Designer</PageTitle>

<p class="back"><a href="dialogs">← Dialoge</a></p>

@if (_detail is null)
{
    <h1>Dialog</h1>

    @if (_error is not null)
    {
        <div class="banner err">@_error</div>
    }
    else
    {
        <p class="empty">Wird geladen …</p>
    }
}
else
{
    <h1>
        @_detail.Dialog.Name
        @if (_detail.Dialog.IsPublished)
        {
            <span class="badge badge-published">Veröffentlicht</span>
        }
        else
        {
            <span class="badge badge-draft">Entwurf</span>
        }
    </h1>

    <p class="intro">
        Version @_detail.Dialog.Version · angelegt @_detail.Dialog.CreatedAt.LocalDateTime.ToString("g")
        · zuletzt geändert @_detail.Dialog.UpdatedAt.LocalDateTime.ToString("g")
    </p>

    @if (_detail.Dialog.IsPublished)
    {
        <div class="banner warn">
            Dieser Dialog ist veröffentlicht. Laufende Sessions pinnen ihre Dialog-Version und brechen
            durch Änderungen nicht – trotzdem empfiehlt es sich, ihn vor dem Bearbeiten zurückzuziehen.
        </div>
    }

    @if (_error is not null)
    {
        <div class="banner err">@_error</div>
    }
    @if (_message is not null)
    {
        <div class="banner ok">@_message</div>
    }

    <div class="editor">
        <h2>Metadaten</h2>
        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="field">
                <label for="key">Schlüssel</label>
                <InputText id="key" class="input" @bind-Value="_form.Key" />
                <ValidationMessage For="() => _form.Key" />
            </div>

            <div class="field">
                <label for="name">Name</label>
                <InputText id="name" class="input" @bind-Value="_form.Name" />
                <ValidationMessage For="() => _form.Name" />
            </div>

            <div class="field">
                <label for="description">Beschreibung</label>
                <InputTextArea id="description" class="input" rows="2" @bind-Value="_form.Description" />
            </div>

            <div class="field">
                <label for="startQuestion">Einstiegsfrage</label>
                <InputSelect id="startQuestion" class="input" @bind-Value="_form.StartQuestionId"
                             disabled="@(_detail.Questions.Count == 0)">
                    <option value="">— keine —</option>
                    @foreach (var question in _detail.Questions)
                    {
                        <option value="@question.Id">@question.Key — @question.Text</option>
                    }
                </InputSelect>
                @if (_detail.Questions.Count == 0)
                {
                    <span class="hint">Erst unten eine Frage anlegen – dann lässt sich hier die Einstiegsfrage wählen.</span>
                }
                else
                {
                    <span class="hint">Ohne Einstiegsfrage lässt sich der Dialog nicht veröffentlichen.</span>
                }
            </div>

            <div class="actions">
                <button type="submit" class="btn btn-primary" disabled="@_busy">Speichern</button>
                <button type="button" class="btn" disabled="@_busy" @onclick="ResetForm">Zurücksetzen</button>
            </div>
        </EditForm>
    </div>

    <div class="editor">
        <h2>Fragen</h2>

        @if (_detail.Questions.Count == 0)
        {
            <p class="empty">Noch keine Fragen angelegt.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Schlüssel</th>
                        <th>Text</th>
                        <th>Typ</th>
                        <th>Pflicht</th>
                        <th>Optionen</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < _detail.Questions.Count; index++)
                    {
                        // Lokale Kopien: die Lambdas der Schaltflächen liefen sonst gegen den
                        // Schleifenzustand nach dem letzten Durchlauf.
                        var position = index;
                        var question = _detail.Questions[index];

                        <tr>
                            <td>@(position + 1)</td>
                            <td class="mono">
                                @question.Key
                                @if (_detail.Dialog.StartQuestionId == question.Id)
                                {
                                    <span class="badge badge-start">Einstieg</span>
                                }
                            </td>
                            <td>@question.Text</td>
                            <td>@QuestionTypeLabels.Describe(question.Type)</td>
                            <td>@(question.IsRequired ? "ja" : "nein")</td>
                            <td>@(QuestionTypeLabels.UsesOptions(question.Type) ? question.Options.Count.ToString() : "—")</td>
                            <td class="row-actions">
                                <button class="btn" title="Nach oben"
                                        disabled="@(_busy || position == 0)"
                                        @onclick="() => MoveQuestionAsync(position, position - 1)">↑</button>
                                <button class="btn" title="Nach unten"
                                        disabled="@(_busy || position == _detail.Questions.Count - 1)"
                                        @onclick="() => MoveQuestionAsync(position, position + 1)">↓</button>
                                <button class="btn" @onclick="() => OpenQuestion(question)">Bearbeiten</button>

                                @if (_confirmDeleteQuestionId == question.Id)
                                {
                                    <span class="confirm">Frage samt Optionen und Übergängen löschen?</span>
                                    <button class="btn btn-danger" disabled="@_busy"
                                            @onclick="() => DeleteQuestionAsync(question)">Ja, löschen</button>
                                    <button class="btn" disabled="@_busy"
                                            @onclick="() => _confirmDeleteQuestionId = null">Abbrechen</button>
                                }
                                else
                                {
                                    <button class="btn btn-danger" disabled="@_busy"
                                            @onclick="() => _confirmDeleteQuestionId = question.Id">Löschen</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (_newQuestion is null)
        {
            <div class="actions">
                <button class="btn btn-primary" disabled="@_busy" @onclick="StartCreateQuestion">Neue Frage</button>
            </div>
        }
        else
        {
            <EditForm Model="_newQuestion" OnValidSubmit="CreateQuestionAsync">
                <DataAnnotationsValidator />

                <div class="field">
                    <label for="questionKey">Schlüssel</label>
                    <InputText id="questionKey" class="input" @bind-Value="_newQuestion.Key" />
                    <span class="hint">
                        Fachlicher, stabiler Schlüssel – im Dialog eindeutig und im Ausdruckskontext des
                        Branchings sichtbar (z. B. <code>vorname</code>).
                    </span>
                    <ValidationMessage For="() => _newQuestion.Key" />
                </div>

                <div class="field">
                    <label for="questionText">Fragetext</label>
                    <InputTextArea id="questionText" class="input" rows="2" @bind-Value="_newQuestion.Text" />
                    <ValidationMessage For="() => _newQuestion.Text" />
                </div>

                <div class="field">
                    <label for="questionType">Typ</label>
                    <InputSelect id="questionType" class="input" @bind-Value="_newQuestion.Type">
                        @foreach (var type in Enum.GetValues<QuestionType>())
                        {
                            <option value="@type">@QuestionTypeLabels.Describe(type)</option>
                        }
                    </InputSelect>
                </div>

                <div class="field check">
                    <InputCheckbox id="questionRequired" @bind-Value="_newQuestion.IsRequired" />
                    <label for="questionRequired">Antwort erforderlich</label>
                </div>

                <div class="actions">
                    <button type="submit" class="btn btn-primary" disabled="@_busy">Anlegen</button>
                    <button type="button" class="btn" disabled="@_busy" @onclick="() => _newQuestion = null">Abbrechen</button>
                </div>
            </EditForm>
        }
    </div>

    <div class="editor">
        <h2>Übergänge (Branching)</h2>

        @if (_detail.Questions.Count == 0)
        {
            <p class="empty">Erst Fragen anlegen – Übergänge verbinden Fragen miteinander.</p>
        }
        else
        {
            <p class="hint">
                Je Ausgangsfrage werden die Übergänge von oben nach unten geprüft; der erste zutreffende
                gewinnt. Greift keiner, kommt der Default-Übergang zum Zug.
            </p>

            @foreach (var question in _detail.Questions)
            {
                // Lokale Kopie: die Lambdas der Schaltflächen liefen sonst gegen den Schleifenzustand
                // nach dem letzten Durchlauf.
                var source = question;
                var outgoing = Outgoing(source.Id);

                <h3 class="group">
                    <span class="mono">@source.Key</span>
                    <span class="group-text">— @source.Text</span>
                    <button class="btn" disabled="@_busy" @onclick="() => StartCreateTransition(source.Id)">
                        + Übergang
                    </button>
                </h3>

                @if (outgoing.Count == 0)
                {
                    <p class="hint">Keine Übergänge – der Dialog endet nach dieser Frage.</p>
                }
                else
                {
                    @foreach (var warning in GroupWarnings(outgoing))
                    {
                        <div class="banner warn">@warning</div>
                    }

                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Bedingung</th>
                                <th>Ziel</th>
                                <th>Art</th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var index = 0; index < outgoing.Count; index++)
                            {
                                var position = index;
                                var transition = outgoing[index];

                                <tr>
                                    <td>@(position + 1)</td>
                                    <td class="mono">
                                        @(string.IsNullOrWhiteSpace(transition.Expression)
                                            ? "— bedingungslos —"
                                            : transition.Expression)
                                    </td>
                                    <td class="mono">@QuestionLabel(transition.TargetQuestionId)</td>
                                    <td>
                                        @if (transition.IsDefault)
                                        {
                                            <span class="badge badge-default">Default</span>
                                        }
                                        @if (IsBackJump(transition))
                                        {
                                            <span class="badge badge-loop" title="Zeigt auf eine frühere Frage – Zyklus/Schleife">Rücksprung</span>
                                        }
                                    </td>
                                    <td class="row-actions">
                                        <button class="btn" title="Nach oben"
                                                disabled="@(_busy || position == 0)"
                                                @onclick="() => MoveTransitionAsync(source.Id, position, position - 1)">↑</button>
                                        <button class="btn" title="Nach unten"
                                                disabled="@(_busy || position == outgoing.Count - 1)"
                                                @onclick="() => MoveTransitionAsync(source.Id, position, position + 1)">↓</button>
                                        <button class="btn" @onclick="() => OpenTransition(transition)">Bearbeiten</button>

                                        @if (_confirmDeleteTransitionId == transition.Id)
                                        {
                                            <span class="confirm">Übergang löschen?</span>
                                            <button class="btn btn-danger" disabled="@_busy"
                                                    @onclick="() => DeleteTransitionAsync(transition)">Ja, löschen</button>
                                            <button class="btn" disabled="@_busy"
                                                    @onclick="() => _confirmDeleteTransitionId = null">Abbrechen</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-danger" disabled="@_busy"
                                                    @onclick="() => _confirmDeleteTransitionId = transition.Id">Löschen</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }

            @if (Orphans().Count > 0)
            {
                <div class="banner warn">
                    @Orphans().Count Übergang/Übergänge zeigen auf eine unbekannte Ausgangsfrage und werden
                    nie ausgewertet. Sie lassen sich nur löschen:
                    @foreach (var orphan in Orphans())
                    {
                        var stale = orphan;
                        <button class="btn btn-danger" disabled="@_busy"
                                @onclick="() => DeleteTransitionAsync(stale)">
                            @stale.Id löschen
                        </button>
                    }
                </div>
            }

            @if (_newTransition is null)
            {
                <div class="actions">
                    <button class="btn btn-primary" disabled="@_busy"
                            @onclick="() => StartCreateTransition(null)">Neuer Übergang</button>
                </div>
            }
            else
            {
                <EditForm Model="_newTransition" OnValidSubmit="CreateTransitionAsync">
                    <DataAnnotationsValidator />

                    <div class="field-row">
                        <div class="field">
                            <label for="transitionFrom">Ausgangsfrage</label>
                            <InputSelect id="transitionFrom" class="input" @bind-Value="_newTransition.FromQuestionId">
                                <option value="">— wählen —</option>
                                @foreach (var question in _detail.Questions)
                                {
                                    <option value="@question.Id">@question.Key — @question.Text</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => _newTransition.FromQuestionId" />
                        </div>

                        <div class="field">
                            <label for="transitionTarget">Zielfrage</label>
                            <InputSelect id="transitionTarget" class="input" @bind-Value="_newTransition.TargetQuestionId">
                                <option value="">— wählen —</option>
                                @foreach (var question in _detail.Questions)
                                {
                                    <option value="@question.Id">@question.Key — @question.Text</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => _newTransition.TargetQuestionId" />
                        </div>
                    </div>

                    <div class="field check">
                        <InputCheckbox id="transitionDefault" @bind-Value="_newTransition.IsDefault" />
                        <label for="transitionDefault">Default-Übergang (greift, wenn keine Bedingung zutrifft)</label>
                    </div>

                    <span class="hint">
                        Die Bedingung wird anschließend im Übergangs-Editor gepflegt – dort wird sie live
                        gegen die Fragen dieses Dialogs geprüft.
                    </span>

                    <div class="actions">
                        <button type="submit" class="btn btn-primary" disabled="@_busy">Anlegen</button>
                        <button type="button" class="btn" disabled="@_busy"
                                @onclick="() => _newTransition = null">Abbrechen</button>
                    </div>
                </EditForm>
            }
        }
    </div>

    <div class="editor">
        <h2>Schleifen (Loops)</h2>

        @if (_detail.Questions.Count == 0)
        {
            <p class="empty">Erst Fragen und Übergänge anlegen – eine Schleife markiert einen vorhandenen Zyklus.</p>
        }
        else
        {
            <p class="hint">
                Eine Schleife entsteht aus den Übergängen: Ein Rücksprung auf eine frühere Frage bildet den
                Zyklus. Der Marker sagt der Laufzeit nur, dass die Antworten des Bereichs je Iteration unter
                dem Collection-Schlüssel <em>gesammelt</em> statt überschrieben werden.
            </p>

            @if (_detail.Loops.Count == 0)
            {
                <p class="empty">Noch keine Schleifen markiert.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Collection</th>
                            <th>Einstieg</th>
                            <th>Breaking</th>
                            <th>Bereich</th>
                            <th>Status</th>
                            <th>Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var insight in _loops)
                        {
                            // Lokale Kopie: die Lambdas der Schaltflächen liefen sonst gegen den
                            // Schleifenzustand nach dem letzten Durchlauf.
                            var loop = insight.Loop;

                            <tr>
                                <td class="mono">@loop.CollectionKey</td>
                                <td class="mono">@QuestionLabel(loop.EntryQuestionId)</td>
                                <td class="mono">@QuestionLabel(loop.BreakingQuestionId)</td>
                                <td>@insight.Body.Count Frage(n)</td>
                                <td>
                                    @if (insight.Warnings.Count == 0)
                                    {
                                        <span class="badge badge-loop">Schleife</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-draft"
                                              title="@string.Join(" ", insight.Warnings)">
                                            @insight.Warnings.Count Warnung(en)
                                        </span>
                                    }
                                </td>
                                <td class="row-actions">
                                    <button class="btn" @onclick="() => OpenLoop(loop)">Bearbeiten</button>

                                    @if (_confirmDeleteLoopId == loop.Id)
                                    {
                                        <span class="confirm">Marker löschen? Der Zyklus selbst bleibt bestehen.</span>
                                        <button class="btn btn-danger" disabled="@_busy"
                                                @onclick="() => DeleteLoopAsync(loop)">Ja, löschen</button>
                                        <button class="btn" disabled="@_busy"
                                                @onclick="() => _confirmDeleteLoopId = null">Abbrechen</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-danger" disabled="@_busy"
                                                @onclick="() => _confirmDeleteLoopId = loop.Id">Löschen</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @if (UnmarkedBackJumps().Count > 0)
            {
                <div class="banner warn">
                    Rücksprung ohne Schleifen-Marker: Die Antworten dieses Zyklus werden zur Laufzeit
                    <strong>überschrieben</strong> statt je Iteration gesammelt.
                    @foreach (var candidate in UnmarkedBackJumps())
                    {
                        var backJump = candidate;
                        <button class="btn" disabled="@_busy" @onclick="() => StartCreateLoop(backJump)">
                            @QuestionLabel(backJump.FromQuestionId) → @QuestionLabel(backJump.TargetQuestionId)
                            als Schleife markieren
                        </button>
                    }
                </div>
            }

            @if (_newLoop is null)
            {
                <div class="actions">
                    <button class="btn btn-primary" disabled="@_busy"
                            @onclick="() => StartCreateLoop(null)">Neue Schleife</button>
                </div>
            }
            else
            {
                <EditForm Model="_newLoop" OnValidSubmit="CreateLoopAsync">
                    <DataAnnotationsValidator />

                    <div class="field-row">
                        <div class="field">
                            <label for="loopEntry">Einstiegsfrage</label>
                            <InputSelect id="loopEntry" class="input" @bind-Value="_newLoop.EntryQuestionId">
                                <option value="">— wählen —</option>
                                @foreach (var question in _detail.Questions)
                                {
                                    <option value="@question.Id">@question.Key — @question.Text</option>
                                }
                            </InputSelect>
                            <span class="hint">Ziel des Rücksprungs; ihre Antwort wird je Iteration gesammelt.</span>
                            <ValidationMessage For="() => _newLoop.EntryQuestionId" />
                        </div>

                        <div class="field">
                            <label for="loopBreaking">Breaking Question</label>
                            <InputSelect id="loopBreaking" class="input" @bind-Value="_newLoop.BreakingQuestionId">
                                <option value="">— wählen —</option>
                                @foreach (var question in _detail.Questions)
                                {
                                    <option value="@question.Id">@question.Key — @question.Text</option>
                                }
                            </InputSelect>
                            <span class="hint">Frage, an der über Rücksprung oder Ausstieg entschieden wird.</span>
                            <ValidationMessage For="() => _newLoop.BreakingQuestionId" />
                        </div>
                    </div>

                    <div class="field">
                        <label for="loopKey">Collection-Schlüssel</label>
                        <InputText id="loopKey" class="input mono" @bind-Value="_newLoop.CollectionKey" />
                        <span class="hint">
                            Bezeichner der gesammelten Antworten im Ausdruckskontext, z. B.
                            <code>skills</code> für <code>skills.Count &gt; 0</code>.
                        </span>
                        <ValidationMessage For="() => _newLoop.CollectionKey" />
                    </div>

                    <div class="actions">
                        <button type="submit" class="btn btn-primary" disabled="@_busy">Anlegen</button>
                        <button type="button" class="btn" disabled="@_busy"
                                @onclick="() => _newLoop = null">Abbrechen</button>
                    </div>
                </EditForm>
            }
        }
    </div>

    <div class="editor">
        <h2>Trigger</h2>

        <p class="hint">
            Trigger sind Rückkanäle in die Host-Anwendung. Ein <strong>Webhook</strong> wird von der
            Engine selbst als HTTP-POST an die konfigurierte URL zugestellt; ein
            <strong>In-Process</strong>-Eintrag hält nur fest, dass die Host-App an dieser Stelle mit
            einem eigenen <code>INotificationHandler&lt;T&gt;</code> reagiert – die Notification wird
            ohnehin publiziert.
        </p>

        @if (_detail.Triggers.Count == 0)
        {
            <p class="empty">Noch keine Trigger angelegt.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Zeitpunkt</th>
                        <th>Frage</th>
                        <th>Kanal</th>
                        <th>Ziel</th>
                        <th>Bedingung</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _detail.Triggers)
                    {
                        // Lokale Kopie: die Lambdas der Schaltflächen liefen sonst gegen den
                        // Schleifenzustand nach dem letzten Durchlauf.
                        var trigger = entry;

                        <tr>
                            <td>@TriggerLabels.Describe(trigger.Scope)</td>
                            <td class="mono">
                                @(trigger.QuestionId is { } questionId ? QuestionLabel(questionId) : "—")
                            </td>
                            <td>@TriggerLabels.Describe(trigger.Kind)</td>
                            <td class="mono">@TriggerTarget(trigger)</td>
                            <td class="mono">
                                @(string.IsNullOrWhiteSpace(trigger.Expression)
                                    ? "— bedingungslos —"
                                    : trigger.Expression)
                            </td>
                            <td class="row-actions">
                                <button class="btn" @onclick="() => OpenTrigger(trigger)">Bearbeiten</button>

                                @if (_confirmDeleteTriggerId == trigger.Id)
                                {
                                    <span class="confirm">Trigger löschen?</span>
                                    <button class="btn btn-danger" disabled="@_busy"
                                            @onclick="() => DeleteTriggerAsync(trigger)">Ja, löschen</button>
                                    <button class="btn" disabled="@_busy"
                                            @onclick="() => _confirmDeleteTriggerId = null">Abbrechen</button>
                                }
                                else
                                {
                                    <button class="btn btn-danger" disabled="@_busy"
                                            @onclick="() => _confirmDeleteTriggerId = trigger.Id">Löschen</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (_newTrigger is null)
        {
            <div class="actions">
                <button class="btn btn-primary" disabled="@_busy" @onclick="StartCreateTrigger">Neuer Trigger</button>
            </div>
        }
        else
        {
            <EditForm Model="_newTrigger" OnValidSubmit="CreateTriggerAsync">
                <DataAnnotationsValidator />

                <div class="field-row">
                    <div class="field">
                        <label for="triggerScope">Zeitpunkt</label>
                        <InputSelect id="triggerScope" class="input" @bind-Value="_newTrigger.Scope">
                            @foreach (var scope in Enum.GetValues<TriggerScope>())
                            {
                                <option value="@scope">@TriggerLabels.Describe(scope)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="field">
                        <label for="triggerKind">Kanal</label>
                        <InputSelect id="triggerKind" class="input" @bind-Value="_newTrigger.Kind">
                            @foreach (var kind in Enum.GetValues<TriggerKind>())
                            {
                                <option value="@kind">@TriggerLabels.Describe(kind)</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                @if (TriggerLabels.RequiresQuestion(_newTrigger.Scope))
                {
                    <div class="field">
                        <label for="triggerQuestion">Frage</label>
                        <InputSelect id="triggerQuestion" class="input" @bind-Value="_newTrigger.QuestionId"
                                     disabled="@(_detail.Questions.Count == 0)">
                            <option value="">— wählen —</option>
                            @foreach (var question in _detail.Questions)
                            {
                                <option value="@question.Id">@question.Key — @question.Text</option>
                            }
                        </InputSelect>
                        <span class="hint">Der Trigger löst nur nach dieser Frage aus.</span>
                    </div>
                }

                @if (_newTrigger.Kind == TriggerKind.Webhook)
                {
                    <div class="field">
                        <label for="triggerUrl">Ziel-URL</label>
                        <InputText id="triggerUrl" class="input mono" @bind-Value="_newTrigger.Url" />
                        <span class="hint">Absolute http-/https-Adresse, z. B. <code>https://host.example/flirty/completed</code>.</span>
                    </div>
                }

                <div class="field">
                    <label for="triggerName">Ereignisname (optional)</label>
                    <InputText id="triggerName" class="input mono" @bind-Value="_newTrigger.Name" />
                    <span class="hint">
                        Wird beim Webhook als Header <code>X-Flirty-Trigger</code> mitgeliefert, z. B.
                        <code>order-created</code>.
                    </span>
                </div>

                <span class="hint">
                    Die Bedingung wird anschließend im Trigger-Editor gepflegt – dort wird sie live gegen
                    die Fragen dieses Dialogs geprüft.
                </span>

                <div class="actions">
                    <button type="submit" class="btn btn-primary" disabled="@_busy">Anlegen</button>
                    <button type="button" class="btn" disabled="@_busy"
                            @onclick="() => _newTrigger = null">Abbrechen</button>
                </div>
            </EditForm>
        }
    </div>

    <div class="editor">
        <h2>Testlauf</h2>

        <p class="hint">
            Den Dialog mit der echten Engine durchspielen – auch als Entwurf. Der Lauf legt eine echte
            Session in der Datenbank des aktiven Profils an.
        </p>

        <div class="actions">
            <button class="btn btn-primary"
                    disabled="@(_busy || _detail.Dialog.StartQuestionId is null)"
                    @onclick="OpenTestRunner">
                Durchspielen
            </button>
        </div>

        @if (_detail.Dialog.StartQuestionId is null)
        {
            <p class="hint">Ohne gesetzte (und gespeicherte) Einstiegsfrage gibt es nichts durchzuspielen.</p>
        }
    </div>

    <div class="editor">
        <h2>Veröffentlichung &amp; Löschen</h2>
        <div class="actions">
            @if (_detail.Dialog.IsPublished)
            {
                <button class="btn" disabled="@_busy" @onclick="UnpublishAsync">Zurückziehen</button>
            }
            else
            {
                <button class="btn btn-primary"
                        disabled="@(_busy || _detail.Dialog.StartQuestionId is null)"
                        @onclick="PublishAsync">
                    Veröffentlichen
                </button>
            }

            @if (_confirmDelete)
            {
                <span class="confirm">Wirklich löschen? Der gesamte Dialog-Graph geht verloren.</span>
                <button class="btn btn-danger" disabled="@_busy" @onclick="DeleteAsync">Ja, löschen</button>
                <button class="btn" disabled="@_busy" @onclick="() => _confirmDelete = false">Abbrechen</button>
            }
            else
            {
                <button class="btn btn-danger" disabled="@_busy" @onclick="() => _confirmDelete = true">Löschen</button>
            }
        </div>

        @if (!_detail.Dialog.IsPublished && _detail.Dialog.StartQuestionId is null)
        {
            <p class="hint">
                Zum Veröffentlichen muss oben eine Einstiegsfrage gesetzt (und gespeichert) sein.
            </p>
        }
    </div>
}

@code {
    /// <summary>Der Primärschlüssel des angezeigten Dialogs (aus der Route).</summary>
    [Parameter]
    public Guid Id { get; set; }

    private DialogDetail? _detail;
    private IReadOnlyList<LoopInsight> _loops = [];
    private DialogFormModel _form = new();
    private QuestionFormModel? _newQuestion;
    private TransitionFormModel? _newTransition;
    private LoopFormModel? _newLoop;
    private TriggerFormModel? _newTrigger;
    private string? _error;
    private string? _message;
    private bool _busy;
    private bool _confirmDelete;
    private Guid? _confirmDeleteQuestionId;
    private Guid? _confirmDeleteTransitionId;
    private Guid? _confirmDeleteLoopId;
    private Guid? _confirmDeleteTriggerId;
    private Guid _loadedId;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }

        _loadedId = Id;
        _message = null;
        _confirmDelete = false;
        _confirmDeleteQuestionId = null;
        _confirmDeleteTransitionId = null;
        _confirmDeleteLoopId = null;
        _confirmDeleteTriggerId = null;
        _newQuestion = null;
        _newTransition = null;
        _newLoop = null;
        _newTrigger = null;
        await ReloadAsync();
    }

    /// <summary>
    /// Lädt den Dialog samt Graph neu.
    /// </summary>
    /// <param name="resetForm">
    /// Ob das Metadaten-Formular überschrieben werden soll. Bei Fragen-Operationen bewusst
    /// <see langword="false"/>: sonst gingen dort gerade getippte, noch nicht gespeicherte Metadaten
    /// verloren. Die Einstiegsfrage wird trotzdem abgeglichen, falls sie serverseitig wegfiel.
    /// </param>
    private async Task ReloadAsync(bool resetForm = true)
    {
        var result = await Admin.ExecuteAsync((sender, token) => sender.Send(new GetDialogQuery(Id), token));
        _detail = result.Value;
        _error = result.Error;
        _loops = _detail is null ? [] : LoopAnalyzer.Analyze(_detail);

        if (resetForm)
        {
            ResetForm();
        }
        else if (_detail is not null
            && _form.StartQuestionId is { } selected
            && _detail.Questions.All(question => question.Id != selected))
        {
            // Die gewählte Einstiegsfrage existiert nicht mehr (gelöscht) -> auf den Serverstand zurück.
            _form.StartQuestionId = _detail.Dialog.StartQuestionId;
        }
    }

    private void ResetForm()
    {
        if (_detail is not null)
        {
            _form = DialogFormModel.From(_detail.Dialog);
        }
    }

    private async Task SaveAsync()
        => await RunAsync(
            (sender, token) => sender.Send(
                new UpdateDialogCommand(Id, _form.Key, _form.Name, _form.Description, _form.StartQuestionId), token),
            "Änderungen gespeichert.");

    private async Task PublishAsync()
        => await RunAsync((sender, token) => sender.Send(new PublishDialogCommand(Id), token), "Dialog veröffentlicht.");

    private async Task UnpublishAsync()
        => await RunAsync(
            (sender, token) => sender.Send(new UnpublishDialogCommand(Id), token), "Veröffentlichung zurückgenommen.");

    /// <summary>
    /// Führt eine schreibende Operation aus, zeigt Erfolg oder Fehler an und lädt den Dialog neu (die
    /// Commands liefern nur ihren eigenen Ausschnitt zurück, die Ansicht braucht den ganzen Graphen).
    /// </summary>
    /// <typeparam name="TResult">Der Ergebnistyp der Operation.</typeparam>
    /// <param name="operation">Die auszuführende Admin-Nachricht.</param>
    /// <param name="successMessage">Die bei Erfolg angezeigte Meldung.</param>
    /// <param name="resetForm">Ob das Metadaten-Formular vom Serverstand überschrieben werden soll.</param>
    /// <returns><see langword="true"/>, wenn die Operation erfolgreich war.</returns>
    private async Task<bool> RunAsync<TResult>(
        Func<ISender, CancellationToken, ValueTask<TResult>> operation,
        string successMessage,
        bool resetForm = true)
    {
        _busy = true;
        _message = null;
        try
        {
            var result = await Admin.ExecuteAsync(operation);
            if (!result.Success)
            {
                _error = result.Error;
                return false;
            }

            _error = null;
            _message = successMessage;
            await ReloadAsync(resetForm);
            return true;
        }
        finally
        {
            _busy = false;
        }
    }

    // ---- Fragen (#39) -----------------------------------------------------------------------------

    private void StartCreateQuestion() => _newQuestion = new QuestionFormModel();

    private void OpenQuestion(QuestionDetail question)
        => Navigation.NavigateTo($"dialogs/{Id}/questions/{question.Id}");

    /// <summary>
    /// Legt eine Frage am Ende des Dialogs an. Validierungsregeln und Antwortoptionen werden bewusst
    /// nicht hier, sondern im Frage-Editor gepflegt – so bleibt das Anlegen mehrerer Fragen zügig.
    /// </summary>
    private async Task CreateQuestionAsync()
    {
        if (_detail is null || _newQuestion is null)
        {
            return;
        }

        var model = _newQuestion;
        var order = _detail.Questions.Count == 0 ? 0 : _detail.Questions.Max(question => question.Order) + 1;

        var created = await RunAsync<QuestionDetail>(
            (sender, token) => sender.Send(
                new CreateQuestionCommand(Id, model.Key, model.Text, model.Type, order, model.IsRequired, null),
                token),
            $"Frage „{model.Key}“ angelegt.",
            resetForm: false);

        if (created)
        {
            _newQuestion = null;
        }
    }

    /// <summary>
    /// Verschiebt eine Frage um eine Position. Geschrieben wird der <b>Positionsindex</b> als neue
    /// <c>Order</c> – das repariert nebenbei doppelte oder lückenhafte Werte, bei denen ein reines
    /// Vertauschen der beiden Zahlen wirkungslos bliebe. Beide Updates laufen in <b>einem</b>
    /// Gateway-Aufruf, also im selben DI-Scope mit einem Fehlerpfad.
    /// </summary>
    /// <param name="from">Die aktuelle Position der Frage.</param>
    /// <param name="to">Die Zielposition.</param>
    private async Task MoveQuestionAsync(int from, int to)
    {
        if (_detail is null || to < 0 || to >= _detail.Questions.Count)
        {
            return;
        }

        var ordered = _detail.Questions.ToList();
        (ordered[from], ordered[to]) = (ordered[to], ordered[from]);

        var changed = ordered
            .Select((question, index) => (Question: question, Index: index))
            .Where(entry => entry.Question.Order != entry.Index)
            .ToList();

        if (changed.Count == 0)
        {
            return;
        }

        await RunAsync<Unit>(
            async (sender, token) =>
            {
                foreach (var (question, index) in changed)
                {
                    _ = await sender.Send(
                        new UpdateQuestionCommand(
                            Id, question.Id, question.Key, question.Text, question.Type, index,
                            question.IsRequired, question.ValidationRules),
                        token);
                }

                return Unit.Value;
            },
            "Reihenfolge geändert.",
            resetForm: false);
    }

    private async Task DeleteQuestionAsync(QuestionDetail question)
    {
        _confirmDeleteQuestionId = null;

        await RunAsync<Unit>(
            (sender, token) => sender.Send(new DeleteQuestionCommand(Id, question.Id), token),
            $"Frage „{question.Key}“ gelöscht.",
            resetForm: false);
    }

    // ---- Übergänge / Branching (#40) --------------------------------------------------------------

    /// <summary>Die ausgehenden Übergänge einer Frage in Auswertungsreihenfolge.</summary>
    /// <param name="questionId">Die Ausgangsfrage.</param>
    /// <returns>Die Übergänge nach <c>Priority</c> sortiert.</returns>
    private IReadOnlyList<TransitionDetail> Outgoing(Guid questionId)
        => _detail is null
            ? []
            : [.. _detail.Transitions
                .Where(transition => transition.FromQuestionId == questionId)
                .OrderBy(transition => transition.Priority)];

    /// <summary>
    /// Übergänge, deren Ausgangsfrage nicht (mehr) zum Dialog gehört. Über den Designer entstehen sie
    /// nicht – die Admin-API prüft Frage-Verweise aber bewusst nicht, deshalb werden sie sichtbar
    /// gemacht statt still verschluckt.
    /// </summary>
    private IReadOnlyList<TransitionDetail> Orphans()
        => _detail is null
            ? []
            : [.. _detail.Transitions.Where(
                transition => _detail.Questions.All(question => question.Id != transition.FromQuestionId))];

    private string QuestionLabel(Guid questionId)
        => _detail?.Questions.FirstOrDefault(question => question.Id == questionId)?.Key
            ?? $"unbekannt ({questionId})";

    /// <summary>
    /// Gibt an, ob der Übergang auf eine frühere (oder dieselbe) Frage zeigt – damit entsteht ein Zyklus,
    /// also eine Schleife. Der Marker dazu wird im Abschnitt „Schleifen" gepflegt.
    /// </summary>
    private bool IsBackJump(TransitionDetail transition)
    {
        if (_detail is null)
        {
            return false;
        }

        var from = _detail.Questions.ToList().FindIndex(question => question.Id == transition.FromQuestionId);
        var target = _detail.Questions.ToList().FindIndex(question => question.Id == transition.TargetQuestionId);

        return from >= 0 && target >= 0 && target <= from;
    }

    /// <summary>
    /// Meldet Konfigurationen, die zur Laufzeit anders wirken als gedacht. Die Regeln spiegeln den
    /// <c>TransitionResolver</c> der Engine: erster zutreffender <b>nicht</b>-Default gewinnt, sonst der
    /// erste Default; trifft nichts, wirft die Runtime.
    /// </summary>
    /// <param name="outgoing">Die Übergänge einer Ausgangsfrage in Auswertungsreihenfolge.</param>
    /// <returns>Die anzuzeigenden Warnungen (leer, wenn alles stimmig ist).</returns>
    private static IReadOnlyList<string> GroupWarnings(IReadOnlyList<TransitionDetail> outgoing)
    {
        var warnings = new List<string>();
        var defaults = outgoing.Where(transition => transition.IsDefault).ToList();
        var unconditional = outgoing
            .Select((transition, index) => (Transition: transition, Index: index))
            .FirstOrDefault(entry =>
                !entry.Transition.IsDefault && string.IsNullOrWhiteSpace(entry.Transition.Expression));

        if (defaults.Count == 0 && unconditional.Transition is null)
        {
            warnings.Add(
                "Kein Default-Übergang: Trifft zur Laufzeit keine Bedingung zu, bricht die Session mit "
                + "einem Fehler ab.");
        }

        if (defaults.Count > 1)
        {
            warnings.Add("Mehrere Default-Übergänge – es greift nur der oberste.");
        }

        if (defaults.Any(transition => !string.IsNullOrWhiteSpace(transition.Expression)))
        {
            warnings.Add("Die Bedingung eines Default-Übergangs wird zur Laufzeit nicht ausgewertet.");
        }

        if (unconditional.Transition is not null && unconditional.Index < outgoing.Count - 1)
        {
            warnings.Add(
                $"Der bedingungslose Übergang an Position {unconditional.Index + 1} greift immer – die "
                + "nachfolgenden Übergänge werden nie geprüft.");
        }

        return warnings;
    }

    private void StartCreateTransition(Guid? fromQuestionId)
        => _newTransition = new TransitionFormModel { FromQuestionId = fromQuestionId };

    private void OpenTransition(TransitionDetail transition)
        => Navigation.NavigateTo($"dialogs/{Id}/transitions/{transition.Id}");

    /// <summary>
    /// Legt einen Übergang am Ende der Prioritätsliste seiner Ausgangsfrage an. Die Bedingung bleibt
    /// zunächst leer – sie wird im Übergangs-Editor gepflegt, wo sie live validiert wird.
    /// </summary>
    private async Task CreateTransitionAsync()
    {
        if (_detail is null || _newTransition is null)
        {
            return;
        }

        var model = _newTransition;
        var from = model.FromQuestionId!.Value;
        var target = model.TargetQuestionId!.Value;
        var siblings = Outgoing(from);
        var priority = siblings.Count == 0 ? 0 : siblings.Max(transition => transition.Priority) + 1;

        var created = await RunAsync<TransitionDetail>(
            (sender, token) => sender.Send(
                new CreateTransitionCommand(Id, from, target, null, priority, model.IsDefault), token),
            $"Übergang {QuestionLabel(from)} → {QuestionLabel(target)} angelegt.",
            resetForm: false);

        if (created)
        {
            _newTransition = null;
        }
    }

    /// <summary>
    /// Verschiebt einen Übergang innerhalb seiner Ausgangsfrage. Wie bei Fragen und Optionen wird der
    /// <b>Positionsindex</b> als neue <c>Priority</c> geschrieben (repariert doppelte/lückenhafte Werte);
    /// alle Updates laufen in einem Gateway-Aufruf.
    /// </summary>
    /// <param name="fromQuestionId">Die Ausgangsfrage, deren Übergänge umsortiert werden.</param>
    /// <param name="from">Die aktuelle Position des Übergangs.</param>
    /// <param name="to">Die Zielposition.</param>
    private async Task MoveTransitionAsync(Guid fromQuestionId, int from, int to)
    {
        var ordered = Outgoing(fromQuestionId).ToList();
        if (to < 0 || to >= ordered.Count)
        {
            return;
        }

        (ordered[from], ordered[to]) = (ordered[to], ordered[from]);

        var changed = ordered
            .Select((transition, index) => (Transition: transition, Index: index))
            .Where(entry => entry.Transition.Priority != entry.Index)
            .ToList();

        if (changed.Count == 0)
        {
            return;
        }

        await RunAsync<Unit>(
            async (sender, token) =>
            {
                foreach (var (transition, index) in changed)
                {
                    _ = await sender.Send(
                        new UpdateTransitionCommand(
                            Id, transition.Id, transition.FromQuestionId, transition.TargetQuestionId,
                            transition.Expression, index, transition.IsDefault),
                        token);
                }

                return Unit.Value;
            },
            "Reihenfolge der Übergänge geändert.",
            resetForm: false);
    }

    private async Task DeleteTransitionAsync(TransitionDetail transition)
    {
        _confirmDeleteTransitionId = null;

        await RunAsync<Unit>(
            (sender, token) => sender.Send(new DeleteTransitionCommand(Id, transition.Id), token),
            "Übergang gelöscht.",
            resetForm: false);
    }

    // ---- Schleifen / Loops (#41) ------------------------------------------------------------------

    /// <summary>
    /// Rücksprung-Übergänge, zu denen (noch) kein Schleifen-Marker passt. Ohne Marker sammelt die
    /// Laufzeit die Antworten des Zyklus nicht, sondern überschreibt sie – deshalb werden sie
    /// ausgewiesen statt still hingenommen.
    /// </summary>
    /// <returns>Die unmarkierten Rücksprünge in Dialog-Reihenfolge.</returns>
    private IReadOnlyList<TransitionDetail> UnmarkedBackJumps()
        => _detail is null
            ? []
            : [.. _detail.Transitions
                .Where(transition => IsBackJump(transition)
                    && !_detail.Loops.Any(loop => loop.EntryQuestionId == transition.TargetQuestionId
                                               && loop.BreakingQuestionId == transition.FromQuestionId))];

    private void OpenLoop(LoopDetail loop)
        => Navigation.NavigateTo($"dialogs/{Id}/loops/{loop.Id}");

    /// <summary>
    /// Öffnet das Anlege-Formular – aus einem Rücksprung heraus bereits vorbelegt: dessen Zielfrage ist
    /// die Einstiegsfrage, dessen Ausgangsfrage die Breaking Question.
    /// </summary>
    /// <param name="backJump">Der Rücksprung, aus dem vorbelegt wird, oder <see langword="null"/> für ein leeres Formular.</param>
    private void StartCreateLoop(TransitionDetail? backJump)
    {
        if (_detail is null || backJump is null)
        {
            _newLoop = new LoopFormModel();
            return;
        }

        var entry = _detail.Questions.FirstOrDefault(question => question.Id == backJump.TargetQuestionId);

        _newLoop = new LoopFormModel
        {
            EntryQuestionId = backJump.TargetQuestionId,
            BreakingQuestionId = backJump.FromQuestionId,
            CollectionKey = entry is null ? string.Empty : LoopFormModel.SuggestCollectionKey(entry.Key, _detail),
        };
    }

    private async Task CreateLoopAsync()
    {
        if (_detail is null || _newLoop is null)
        {
            return;
        }

        var model = _newLoop;

        var created = await RunAsync<LoopDetail>(
            (sender, token) => sender.Send(
                new CreateLoopCommand(
                    Id, model.CollectionKey, model.EntryQuestionId!.Value, model.BreakingQuestionId!.Value),
                token),
            $"Schleife „{model.CollectionKey}“ markiert.",
            resetForm: false);

        if (created)
        {
            _newLoop = null;
        }
    }

    private async Task DeleteLoopAsync(LoopDetail loop)
    {
        _confirmDeleteLoopId = null;

        await RunAsync<Unit>(
            (sender, token) => sender.Send(new DeleteLoopCommand(Id, loop.Id), token),
            $"Schleife „{loop.CollectionKey}“ gelöscht.",
            resetForm: false);
    }

    // ---- Trigger (#42) ----------------------------------------------------------------------------

    private void StartCreateTrigger() => _newTrigger = new TriggerFormModel();

    private void OpenTrigger(TriggerDetail trigger)
        => Navigation.NavigateTo($"dialogs/{Id}/triggers/{trigger.Id}");

    /// <summary>
    /// Beschreibt das Ziel eines Triggers für die Übersicht: die URL des Webhooks bzw. der
    /// Ereignisname. Unlesbare Konfiguration wird roh angezeigt statt verschwiegen – zur Laufzeit
    /// überspringt der Webhook-Handler solche Einträge.
    /// </summary>
    /// <param name="trigger">Der anzuzeigende Trigger.</param>
    /// <returns>Der Anzeigetext für die Spalte „Ziel".</returns>
    private static string TriggerTarget(TriggerDetail trigger)
    {
        if (!TriggerConfig.TryParse(trigger.Config, out var config, out _))
        {
            return trigger.Config;
        }

        return config.Url ?? config.Name ?? "—";
    }

    /// <summary>
    /// Legt einen Trigger an. Die Bedingung bleibt zunächst leer – sie wird im Trigger-Editor gepflegt,
    /// wo sie live validiert wird.
    /// </summary>
    private async Task CreateTriggerAsync()
    {
        if (_detail is null || _newTrigger is null)
        {
            return;
        }

        var model = _newTrigger;

        if (TriggerLabels.RequiresQuestion(model.Scope) && model.QuestionId is null)
        {
            _error = "Bitte eine Frage wählen – ein Trigger nach einer bestimmten Frage braucht ihren Bezug.";
            _message = null;
            return;
        }

        if (!model.TryBuildConfig(out var config, out var configError))
        {
            _error = configError;
            _message = null;
            return;
        }

        var created = await RunAsync<TriggerDetail>(
            (sender, token) => sender.Send(
                new CreateTriggerCommand(
                    Id, model.Scope, model.NormalizedQuestionId(), model.Kind, config, null),
                token),
            $"Trigger „{TriggerLabels.Describe(model.Scope)}“ angelegt.",
            resetForm: false);

        if (created)
        {
            _newTrigger = null;
        }
    }

    private async Task DeleteTriggerAsync(TriggerDetail trigger)
    {
        _confirmDeleteTriggerId = null;

        await RunAsync<Unit>(
            (sender, token) => sender.Send(new DeleteTriggerCommand(Id, trigger.Id), token),
            "Trigger gelöscht.",
            resetForm: false);
    }

    // ---- Test-Runner (#43) ------------------------------------------------------------------------

    private void OpenTestRunner() => Navigation.NavigateTo($"dialogs/{Id}/test");

    private async Task DeleteAsync()
    {
        _busy = true;
        try
        {
            var result = await Admin.ExecuteAsync(
                (sender, token) => sender.Send(new DeleteDialogCommand(Id), token));

            if (!result.Success)
            {
                _error = result.Error;
                _confirmDelete = false;
                return;
            }

            Navigation.NavigateTo("dialogs");
        }
        finally
        {
            _busy = false;
        }
    }
}
