@* Bewusst NICHT "DialogDetail" genannt: der Komponententyp würde sonst den gleichnamigen
   Sichttyp Flirty.Runtime.Admin.DialogDetail verdecken. *@
@page "/dialogs/{Id:guid}"
@rendermode InteractiveServer
@using Mediator
@using Flirty.Domain
@using Flirty.Runtime.Admin
@inject FlirtyAdminGateway Admin
@inject NavigationManager Navigation

<PageTitle>@(_detail?.Dialog.Name ?? "Dialog") · Flirty Designer</PageTitle>

<p class="back"><a href="dialogs">← Dialoge</a></p>

@if (_detail is null)
{
    <h1>Dialog</h1>

    @if (_error is not null)
    {
        <div class="banner err">@_error</div>
    }
    else
    {
        <p class="empty">Wird geladen …</p>
    }
}
else
{
    <h1>
        @_detail.Dialog.Name
        @if (_detail.Dialog.IsPublished)
        {
            <span class="badge badge-published">Veröffentlicht</span>
        }
        else
        {
            <span class="badge badge-draft">Entwurf</span>
        }
    </h1>

    <p class="intro">
        Version @_detail.Dialog.Version · angelegt @_detail.Dialog.CreatedAt.LocalDateTime.ToString("g")
        · zuletzt geändert @_detail.Dialog.UpdatedAt.LocalDateTime.ToString("g")
    </p>

    @if (_detail.Dialog.IsPublished)
    {
        <div class="banner warn">
            Dieser Dialog ist veröffentlicht. Laufende Sessions pinnen ihre Dialog-Version und brechen
            durch Änderungen nicht – trotzdem empfiehlt es sich, ihn vor dem Bearbeiten zurückzuziehen.
        </div>
    }

    @if (_error is not null)
    {
        <div class="banner err">@_error</div>
    }
    @if (_message is not null)
    {
        <div class="banner ok">@_message</div>
    }

    <div class="editor">
        <h2>Metadaten</h2>
        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="field">
                <label for="key">Schlüssel</label>
                <InputText id="key" class="input" @bind-Value="_form.Key" />
                <ValidationMessage For="() => _form.Key" />
            </div>

            <div class="field">
                <label for="name">Name</label>
                <InputText id="name" class="input" @bind-Value="_form.Name" />
                <ValidationMessage For="() => _form.Name" />
            </div>

            <div class="field">
                <label for="description">Beschreibung</label>
                <InputTextArea id="description" class="input" rows="2" @bind-Value="_form.Description" />
            </div>

            <div class="field">
                <label for="startQuestion">Einstiegsfrage</label>
                <InputSelect id="startQuestion" class="input" @bind-Value="_form.StartQuestionId"
                             disabled="@(_detail.Questions.Count == 0)">
                    <option value="">— keine —</option>
                    @foreach (var question in _detail.Questions)
                    {
                        <option value="@question.Id">@question.Key — @question.Text</option>
                    }
                </InputSelect>
                @if (_detail.Questions.Count == 0)
                {
                    <span class="hint">Erst unten eine Frage anlegen – dann lässt sich hier die Einstiegsfrage wählen.</span>
                }
                else
                {
                    <span class="hint">Ohne Einstiegsfrage lässt sich der Dialog nicht veröffentlichen.</span>
                }
            </div>

            <div class="actions">
                <button type="submit" class="btn btn-primary" disabled="@_busy">Speichern</button>
                <button type="button" class="btn" disabled="@_busy" @onclick="ResetForm">Zurücksetzen</button>
            </div>
        </EditForm>
    </div>

    <div class="editor">
        <h2>Fragen</h2>

        @if (_detail.Questions.Count == 0)
        {
            <p class="empty">Noch keine Fragen angelegt.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Schlüssel</th>
                        <th>Text</th>
                        <th>Typ</th>
                        <th>Pflicht</th>
                        <th>Optionen</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < _detail.Questions.Count; index++)
                    {
                        // Lokale Kopien: die Lambdas der Schaltflächen liefen sonst gegen den
                        // Schleifenzustand nach dem letzten Durchlauf.
                        var position = index;
                        var question = _detail.Questions[index];

                        <tr>
                            <td>@(position + 1)</td>
                            <td class="mono">
                                @question.Key
                                @if (_detail.Dialog.StartQuestionId == question.Id)
                                {
                                    <span class="badge badge-start">Einstieg</span>
                                }
                            </td>
                            <td>@question.Text</td>
                            <td>@QuestionTypeLabels.Describe(question.Type)</td>
                            <td>@(question.IsRequired ? "ja" : "nein")</td>
                            <td>@(QuestionTypeLabels.UsesOptions(question.Type) ? question.Options.Count.ToString() : "—")</td>
                            <td class="row-actions">
                                <button class="btn" title="Nach oben"
                                        disabled="@(_busy || position == 0)"
                                        @onclick="() => MoveQuestionAsync(position, position - 1)">↑</button>
                                <button class="btn" title="Nach unten"
                                        disabled="@(_busy || position == _detail.Questions.Count - 1)"
                                        @onclick="() => MoveQuestionAsync(position, position + 1)">↓</button>
                                <button class="btn" @onclick="() => OpenQuestion(question)">Bearbeiten</button>

                                @if (_confirmDeleteQuestionId == question.Id)
                                {
                                    <span class="confirm">Frage samt Optionen und Übergängen löschen?</span>
                                    <button class="btn btn-danger" disabled="@_busy"
                                            @onclick="() => DeleteQuestionAsync(question)">Ja, löschen</button>
                                    <button class="btn" disabled="@_busy"
                                            @onclick="() => _confirmDeleteQuestionId = null">Abbrechen</button>
                                }
                                else
                                {
                                    <button class="btn btn-danger" disabled="@_busy"
                                            @onclick="() => _confirmDeleteQuestionId = question.Id">Löschen</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (_newQuestion is null)
        {
            <div class="actions">
                <button class="btn btn-primary" disabled="@_busy" @onclick="StartCreateQuestion">Neue Frage</button>
            </div>
        }
        else
        {
            <EditForm Model="_newQuestion" OnValidSubmit="CreateQuestionAsync">
                <DataAnnotationsValidator />

                <div class="field">
                    <label for="questionKey">Schlüssel</label>
                    <InputText id="questionKey" class="input" @bind-Value="_newQuestion.Key" />
                    <span class="hint">
                        Fachlicher, stabiler Schlüssel – im Dialog eindeutig und im Ausdruckskontext des
                        Branchings sichtbar (z. B. <code>vorname</code>).
                    </span>
                    <ValidationMessage For="() => _newQuestion.Key" />
                </div>

                <div class="field">
                    <label for="questionText">Fragetext</label>
                    <InputTextArea id="questionText" class="input" rows="2" @bind-Value="_newQuestion.Text" />
                    <ValidationMessage For="() => _newQuestion.Text" />
                </div>

                <div class="field">
                    <label for="questionType">Typ</label>
                    <InputSelect id="questionType" class="input" @bind-Value="_newQuestion.Type">
                        @foreach (var type in Enum.GetValues<QuestionType>())
                        {
                            <option value="@type">@QuestionTypeLabels.Describe(type)</option>
                        }
                    </InputSelect>
                </div>

                <div class="field check">
                    <InputCheckbox id="questionRequired" @bind-Value="_newQuestion.IsRequired" />
                    <label for="questionRequired">Antwort erforderlich</label>
                </div>

                <div class="actions">
                    <button type="submit" class="btn btn-primary" disabled="@_busy">Anlegen</button>
                    <button type="button" class="btn" disabled="@_busy" @onclick="() => _newQuestion = null">Abbrechen</button>
                </div>
            </EditForm>
        }
    </div>

    <div class="editor">
        <h2>Veröffentlichung &amp; Löschen</h2>
        <div class="actions">
            @if (_detail.Dialog.IsPublished)
            {
                <button class="btn" disabled="@_busy" @onclick="UnpublishAsync">Zurückziehen</button>
            }
            else
            {
                <button class="btn btn-primary"
                        disabled="@(_busy || _detail.Dialog.StartQuestionId is null)"
                        @onclick="PublishAsync">
                    Veröffentlichen
                </button>
            }

            @if (_confirmDelete)
            {
                <span class="confirm">Wirklich löschen? Der gesamte Dialog-Graph geht verloren.</span>
                <button class="btn btn-danger" disabled="@_busy" @onclick="DeleteAsync">Ja, löschen</button>
                <button class="btn" disabled="@_busy" @onclick="() => _confirmDelete = false">Abbrechen</button>
            }
            else
            {
                <button class="btn btn-danger" disabled="@_busy" @onclick="() => _confirmDelete = true">Löschen</button>
            }
        </div>

        @if (!_detail.Dialog.IsPublished && _detail.Dialog.StartQuestionId is null)
        {
            <p class="hint">
                Zum Veröffentlichen muss oben eine Einstiegsfrage gesetzt (und gespeichert) sein.
            </p>
        }
    </div>
}

@code {
    /// <summary>Der Primärschlüssel des angezeigten Dialogs (aus der Route).</summary>
    [Parameter]
    public Guid Id { get; set; }

    private DialogDetail? _detail;
    private DialogFormModel _form = new();
    private QuestionFormModel? _newQuestion;
    private string? _error;
    private string? _message;
    private bool _busy;
    private bool _confirmDelete;
    private Guid? _confirmDeleteQuestionId;
    private Guid _loadedId;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == Id)
        {
            return;
        }

        _loadedId = Id;
        _message = null;
        _confirmDelete = false;
        _confirmDeleteQuestionId = null;
        _newQuestion = null;
        await ReloadAsync();
    }

    /// <summary>
    /// Lädt den Dialog samt Graph neu.
    /// </summary>
    /// <param name="resetForm">
    /// Ob das Metadaten-Formular überschrieben werden soll. Bei Fragen-Operationen bewusst
    /// <see langword="false"/>: sonst gingen dort gerade getippte, noch nicht gespeicherte Metadaten
    /// verloren. Die Einstiegsfrage wird trotzdem abgeglichen, falls sie serverseitig wegfiel.
    /// </param>
    private async Task ReloadAsync(bool resetForm = true)
    {
        var result = await Admin.ExecuteAsync((sender, token) => sender.Send(new GetDialogQuery(Id), token));
        _detail = result.Value;
        _error = result.Error;

        if (resetForm)
        {
            ResetForm();
        }
        else if (_detail is not null
            && _form.StartQuestionId is { } selected
            && _detail.Questions.All(question => question.Id != selected))
        {
            // Die gewählte Einstiegsfrage existiert nicht mehr (gelöscht) -> auf den Serverstand zurück.
            _form.StartQuestionId = _detail.Dialog.StartQuestionId;
        }
    }

    private void ResetForm()
    {
        if (_detail is not null)
        {
            _form = DialogFormModel.From(_detail.Dialog);
        }
    }

    private async Task SaveAsync()
        => await RunAsync(
            (sender, token) => sender.Send(
                new UpdateDialogCommand(Id, _form.Key, _form.Name, _form.Description, _form.StartQuestionId), token),
            "Änderungen gespeichert.");

    private async Task PublishAsync()
        => await RunAsync((sender, token) => sender.Send(new PublishDialogCommand(Id), token), "Dialog veröffentlicht.");

    private async Task UnpublishAsync()
        => await RunAsync(
            (sender, token) => sender.Send(new UnpublishDialogCommand(Id), token), "Veröffentlichung zurückgenommen.");

    /// <summary>
    /// Führt eine schreibende Operation aus, zeigt Erfolg oder Fehler an und lädt den Dialog neu (die
    /// Commands liefern nur ihren eigenen Ausschnitt zurück, die Ansicht braucht den ganzen Graphen).
    /// </summary>
    /// <typeparam name="TResult">Der Ergebnistyp der Operation.</typeparam>
    /// <param name="operation">Die auszuführende Admin-Nachricht.</param>
    /// <param name="successMessage">Die bei Erfolg angezeigte Meldung.</param>
    /// <param name="resetForm">Ob das Metadaten-Formular vom Serverstand überschrieben werden soll.</param>
    /// <returns><see langword="true"/>, wenn die Operation erfolgreich war.</returns>
    private async Task<bool> RunAsync<TResult>(
        Func<ISender, CancellationToken, ValueTask<TResult>> operation,
        string successMessage,
        bool resetForm = true)
    {
        _busy = true;
        _message = null;
        try
        {
            var result = await Admin.ExecuteAsync(operation);
            if (!result.Success)
            {
                _error = result.Error;
                return false;
            }

            _error = null;
            _message = successMessage;
            await ReloadAsync(resetForm);
            return true;
        }
        finally
        {
            _busy = false;
        }
    }

    // ---- Fragen (#39) -----------------------------------------------------------------------------

    private void StartCreateQuestion() => _newQuestion = new QuestionFormModel();

    private void OpenQuestion(QuestionDetail question)
        => Navigation.NavigateTo($"dialogs/{Id}/questions/{question.Id}");

    /// <summary>
    /// Legt eine Frage am Ende des Dialogs an. Validierungsregeln und Antwortoptionen werden bewusst
    /// nicht hier, sondern im Frage-Editor gepflegt – so bleibt das Anlegen mehrerer Fragen zügig.
    /// </summary>
    private async Task CreateQuestionAsync()
    {
        if (_detail is null || _newQuestion is null)
        {
            return;
        }

        var model = _newQuestion;
        var order = _detail.Questions.Count == 0 ? 0 : _detail.Questions.Max(question => question.Order) + 1;

        var created = await RunAsync<QuestionDetail>(
            (sender, token) => sender.Send(
                new CreateQuestionCommand(Id, model.Key, model.Text, model.Type, order, model.IsRequired, null),
                token),
            $"Frage „{model.Key}“ angelegt.",
            resetForm: false);

        if (created)
        {
            _newQuestion = null;
        }
    }

    /// <summary>
    /// Verschiebt eine Frage um eine Position. Geschrieben wird der <b>Positionsindex</b> als neue
    /// <c>Order</c> – das repariert nebenbei doppelte oder lückenhafte Werte, bei denen ein reines
    /// Vertauschen der beiden Zahlen wirkungslos bliebe. Beide Updates laufen in <b>einem</b>
    /// Gateway-Aufruf, also im selben DI-Scope mit einem Fehlerpfad.
    /// </summary>
    /// <param name="from">Die aktuelle Position der Frage.</param>
    /// <param name="to">Die Zielposition.</param>
    private async Task MoveQuestionAsync(int from, int to)
    {
        if (_detail is null || to < 0 || to >= _detail.Questions.Count)
        {
            return;
        }

        var ordered = _detail.Questions.ToList();
        (ordered[from], ordered[to]) = (ordered[to], ordered[from]);

        var changed = ordered
            .Select((question, index) => (Question: question, Index: index))
            .Where(entry => entry.Question.Order != entry.Index)
            .ToList();

        if (changed.Count == 0)
        {
            return;
        }

        await RunAsync<Unit>(
            async (sender, token) =>
            {
                foreach (var (question, index) in changed)
                {
                    _ = await sender.Send(
                        new UpdateQuestionCommand(
                            Id, question.Id, question.Key, question.Text, question.Type, index,
                            question.IsRequired, question.ValidationRules),
                        token);
                }

                return Unit.Value;
            },
            "Reihenfolge geändert.",
            resetForm: false);
    }

    private async Task DeleteQuestionAsync(QuestionDetail question)
    {
        _confirmDeleteQuestionId = null;

        await RunAsync<Unit>(
            (sender, token) => sender.Send(new DeleteQuestionCommand(Id, question.Id), token),
            $"Frage „{question.Key}“ gelöscht.",
            resetForm: false);
    }

    private async Task DeleteAsync()
    {
        _busy = true;
        try
        {
            var result = await Admin.ExecuteAsync(
                (sender, token) => sender.Send(new DeleteDialogCommand(Id), token));

            if (!result.Success)
            {
                _error = result.Error;
                _confirmDelete = false;
                return;
            }

            Navigation.NavigateTo("dialogs");
        }
        finally
        {
            _busy = false;
        }
    }
}
